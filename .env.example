# Copy to .env and fill in.

# --- Core ---
SWEEPARR_TIMEZONE=America/New_York
SWEEPARR_SESSION_SECRET=change-me-to-a-long-random-string

# Local admin bootstrap (used only on first boot when no local admin exists)
SWEEPARR_ADMIN_USERNAME=admin
SWEEPARR_ADMIN_PASSWORD=change-me

# --- Optional: seed integration settings into DB on first boot ---
# After first run, configure connections in the Settings UI instead.
SWEEPARR_JELLYFIN_URL=
SWEEPARR_JELLYFIN_API_KEY=
SWEEPARR_JELLYSEERR_URL=
SWEEPARR_JELLYSEERR_API_KEY=
SWEEPARR_SONARR_URL=
SWEEPARR_SONARR_API_KEY=
SWEEPARR_RADARR_URL=
SWEEPARR_RADARR_API_KEY=
SWEEPARR_NTFY_URL=
SWEEPARR_NTFY_TOPIC=
